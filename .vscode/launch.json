{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Server-side (SvelteKit)",
            "runtimeExecutable": "pnpm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ],
            "serverReadyAction": {
                "action": "debugWithChrome",
                "pattern": "local: (http://localhost:([0-9]+))",
                "uriFormat": "%s"
            }
        }
    ]
}